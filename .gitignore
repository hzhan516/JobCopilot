# ============================================
# ResumeAssistant — Unified .gitignore
# ============================================

# ── IDE / Editor ───────────────────────────
/.idea/
/.vscode/
*.swp
*.swo
*~

# ── OS ─────────────────────────────────────
.DS_Store
**/.DS_Store
Thumbs.db

# ── Environment / Secrets ──────────────────
# Never commit actual environment files or credentials
**/.env
**/.env.*
**/.env.local
**/.env.*.local
**/local.env

# Secrets manifests
**/secrets.yaml
**/secrets.yml
**/secrets.json
/security-override.yaml

# Cloud provider credentials
**/*-credentials.json
**/google-credentials.json
**/service-account*.json
/vertex.json

# Crypto material
*.pem
*.key
*.p12
*.pfx
*.jks
*.keystore
id_rsa
id_rsa.pub
.ssh/

# ── Backend (Java / Maven) ─────────────────
**/target/
**/.classpath
**/.factorypath
**/.project
**/.settings/
**/.sisyphus/
*.sisyphus

# Backend runtime
/backend/logs/*
!/backend/logs/README.md
/backend/app/uploads/

# ── Frontend (Node / Vite) ─────────────────
/frontend/node_modules/
/frontend/dist/
/frontend/.vite/
/frontend/.tmp/
/frontend/coverage/
/frontend/.env

# ── AI Service (Python) ──────────────────────
**/.venv/
**/__pycache__/
*.pyc
*.pyo
*.egg-info/
/ai-service/.coverage
/ai-service/coverage.xml
/ai-service/htmlcov/
dist/
build/

# ── Test / Coverage ──────────────────────────
**/.coverage
**/coverage.xml
**/htmlcov/

# ── Project Metadata ─────────────────────────
/PROJECT_STRUCTURE.md
/backend/PROJECT_STRUCTURE.md
/AGENTS.md

# ── Notes / Docs drafts ──────────────────────
/backend/notes/
/notes/
/docs/requirement/

# ── Helm / K8s local overrides ───────────────
/docs/deployment/k8s/helm/resume-assistant/minimal.yaml

# ── Uploads / Generated files ────────────────
**/uploads/
