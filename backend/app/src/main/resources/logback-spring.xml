<?xml version="1.0" encoding="UTF-8"?>
<!--
  Logback 配置文件 / Logback configuration file
  功能：统一后端日志格式，支持按周滚动、保留 4 个备份、总大小限制 100 MB
  Purpose: unify backend log format, weekly rolling, 4 backups, 100 MB total cap
-->
<configuration>
    <!--
      日志格式：时间 线程名 日志等级 Logger名 消息
      Pattern: time thread level logger message
    -->
    <property name="LOG_PATTERN"
              value="%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n"/>
    <!-- 日志路径：支持通过环境变量/系统属性覆盖，默认当前目录下的 logs / Log path: overridable via env, default ./logs -->
    <property name="LOG_PATH" value="${LOG_PATH:-./logs}"/>

    <!-- 控制台输出 / Console appender -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- 文件输出 — 按周滚动 / File appender — weekly rolling -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_PATH}/app.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <!-- 每周归档一次：自然周(ww) / Roll every calendar week -->
            <fileNamePattern>${LOG_PATH}/archived/app.%d{yyyy-ww}.log</fileNamePattern>
            <!-- 保留 4 个备份 / Keep 4 backups -->
            <maxHistory>4</maxHistory>
            <!-- 归档总大小 ≤ 100 MB / Total archive size cap -->
            <totalSizeCap>100MB</totalSizeCap>
            <!-- 启动时清理过期归档 / Clean old archives on startup -->
            <cleanHistoryOnStart>true</cleanHistoryOnStart>
        </rollingPolicy>
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!--
      test 环境仅输出到控制台，避免在 CI 中产生文件日志
      Test profile: console-only to avoid file logs in CI
    -->
    <springProfile name="test">
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>
    </springProfile>

    <!-- dev / prod 环境同时输出到控制台和文件 / Dev & prod: console + file -->
    <springProfile name="!test">
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="FILE"/>
        </root>
    </springProfile>
</configuration>
