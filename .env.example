# =============================================================================
# Resume Assistant - Environment Variables Template
# 简历助手 - 环境变量模板
#
# Please copy this file to `.env`, then fill in the secret values.
# 请将此文件复制为 `.env`，然后填写相应的密钥值。
#
# The only value you must provide for LiteLLM is your free Gemini API key below.
# 您唯一需要为 LiteLLM 提供的值是下方免费的 Gemini API 密钥。
# =============================================================================

# -----------------------------------------------------------------------------
# Database / PostgreSQL
# 数据库 / PostgreSQL
# -----------------------------------------------------------------------------
# These match the Docker Compose defaults.
# 这些值与 Docker Compose 的默认设置保持一致。
POSTGRES_DB=resume_assistant
POSTGRES_USER=resume_user
POSTGRES_PASSWORD=resume_pass
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# -----------------------------------------------------------------------------
# Message Queue / RabbitMQ
# 消息队列 / RabbitMQ
# -----------------------------------------------------------------------------
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest

# -----------------------------------------------------------------------------
# Authentication / JWT
# 身份验证 / JWT
# -----------------------------------------------------------------------------
# replace this with a strong random secret.
# 请将其替换为一个高强度的随机密钥。
JWT_SECRET=change-this-to-a-long-random-secret-at-least-32-characters

# -----------------------------------------------------------------------------
# Frontend / Web app
# 前端 / Web 应用
# -----------------------------------------------------------------------------
VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
VITE_API_BASE_URL=

# -----------------------------------------------------------------------------
# Spring Boot / Backend
# Spring Boot / 后端
# -----------------------------------------------------------------------------
SPRING_PROFILES_ACTIVE=dev

# -----------------------------------------------------------------------------
# LLM Gateway (LiteLLM Configuration) / 大模型网关 (LiteLLM配置)
# -----------------------------------------------------------------------------
# Choose ONE provider by setting the model prefix, then provide the matching API key.
# 通过模型前缀选择一个提供方，然后只需填写对应的 API 密钥。
# Examples:
# Gemini models use the `gemini/` prefix and require GEMINI_API_KEY.
# Gemini 模型使用 `gemini/` 前缀，并需要填写 GEMINI_API_KEY。
# OpenAI models use the `openai/` prefix and require OPENAI_API_KEY.
# OpenAI 模型使用 `openai/` 前缀，并需要填写 OPENAI_API_KEY。
#
# You only need to provide ONE key, depending on the prefixes you choose below.
# 您只需根据下面选择的前缀提供其中一个密钥即可。
GEMINI_API_KEY=[replace-with-your-gemini-api-key]
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=

# Ollama API Base URL (Prefix: ollama/)
# Ollama API 基础 URL (前缀: ollama/)
# Anthropic API Key (Prefix: anthropic/)
# Anthropic API 密钥 (前缀: anthropic/)
# Groq API Key (Prefix: groq/)
# Groq API 密钥 (前缀: groq/)
OLLAMA_API_BASE=http://localhost:11434
LLM_TEXT_MODEL=gemini/gemini-2.5-flash
LLM_VISION_MODEL=gemini/gemini-2.5-flash
LLM_EMBEDDING_MODEL=gemini/text-embedding-004

# -----------------------------------------------------------------------------
# AI service logging
# AI 服务日志
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Vertex AI settings
# Vertex AI 设置
# -----------------------------------------------------------------------------
GOOGLE_CLOUD_PROJECT=ser594-ai-service
VERTEX_AI_LOCATION=global
