# =============================================================================
# Resume Assistant - Environment Variables Template
# 简历助手 - 环境变量模板
#
# Please copy this file to `.env`, then fill in the secret values.
# 请将此文件复制为 `.env`，然后填写相应的密钥值。
#
# The only value you must provide for LiteLLM is your free Gemini API key below.
# 您唯一需要为 LiteLLM 提供的值是下方免费的 Gemini API 密钥。
# =============================================================================

# -----------------------------------------------------------------------------
# Database / PostgreSQL
# 数据库 / PostgreSQL
# -----------------------------------------------------------------------------
# These match the Docker Compose defaults.
# 这些值与 Docker Compose 的默认设置保持一致。
POSTGRES_DB=resume_assistant
POSTGRES_USER=resume_user
POSTGRES_PASSWORD=resume_pass
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# -----------------------------------------------------------------------------
# Message Queue / RabbitMQ
# 消息队列 / RabbitMQ
# -----------------------------------------------------------------------------
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest

# -----------------------------------------------------------------------------
# Authentication / JWT
# 身份验证 / JWT
# -----------------------------------------------------------------------------
# replace this with a strong random secret.
# 请将其替换为一个高强度的随机密钥。
JWT_SECRET=change-this-to-a-long-random-secret-at-least-32-characters

# -----------------------------------------------------------------------------
# Frontend / Web app
# 前端 / Web 应用
# -----------------------------------------------------------------------------
VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
VITE_API_BASE_URL=

# -----------------------------------------------------------------------------
# Spring Boot / Backend
# Spring Boot / 后端
# -----------------------------------------------------------------------------
SPRING_PROFILES_ACTIVE=dev

# -----------------------------------------------------------------------------
# LiteLLM + AI Provider Switch Guide
# LiteLLM AI 提供商切换指南
# -----------------------------------------------------------------------------
# English:
# Choose ONE provider by setting the matching API key and using the matching
# model prefix in LLM_TEXT_MODEL / LLM_VISION_MODEL / LLM_EMBEDDING_MODEL.
#
# 1) Google AI Studio (Gemini) [DEFAULT & RECOMMENDED]:
#    - Set: GEMINI_API_KEY
#    - Use model prefix: gemini/
#    - Example: gemini/gemini-2.5-flash
#    - Note: No credit card or GCP billing required. Just get a free API key.
#
# 2) OpenAI:
#    - Set: OPENAI_API_KEY
#    - Use model prefix: openai/
#    - Example: openai/gpt-4o-mini
#
# 3) Google Cloud Vertex AI (For Enterprise/Legacy workflows):
#    - Set: VERTEX_PROJECT_ID and VERTEX_LOCATION below
#    - Use model prefix: vertex_ai/
#    - Example: vertex_ai/gemini-2.5-flash
#    - Note: Requires Application Default Credentials (ADC) mounted in the container.
#
# 中文：
# 通过设置对应的 API Key，并在模型名称中使用对应的模型前缀，来选择【一个】AI 提供商。
#
# 1）Google AI Studio（Gemini）[默认且推荐]：
#    - 设置：GEMINI_API_KEY
#    - 模型前缀：gemini/
#    - 示例：gemini/gemini-2.5-flash
#    - 注意：不需要信用卡或 GCP 计费，只需获取一个免费的 API 密钥即可。
#
# 2）OpenAI：
#    - 设置：OPENAI_API_KEY
#    - 模型前缀：openai/
#    - 示例：openai/gpt-4o-mini
#
# 3）Google Cloud Vertex AI（用于企业级或旧版工作流）：
#    - 设置：下方的 VERTEX_PROJECT_ID 和 VERTEX_LOCATION
#    - 模型前缀：vertex_ai/
#    - 示例：vertex_ai/gemini-2.5-flash
#    - 注意：即使设置了环境变量，Vertex AI 仍然需要 GCP ADC 凭证文件。
# -----------------------------------------------------------------------------

GEMINI_API_KEY=[replace-with-your-gemini-api-key]
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=

OLLAMA_API_BASE=http://localhost:11434

# -----------------------------------------------------------------------------
# Model Parameters / 模型参数
# -----------------------------------------------------------------------------
LLM_TEXT_MODEL=gemini/gemini-2.5-flash
LLM_VISION_MODEL=gemini/gemini-2.5-flash
LLM_EMBEDDING_MODEL=gemini/gemini-embedding-001
# Must match the output dimension of the selected embedding model.
# 必须与所选嵌入模型的输出维度一致。
LLM_EMBEDDING_MODEL_DIMENSION=1536

# Controls the randomness of the AI. Lower values (e.g., 0.1) are highly deterministic.
# 控制 AI 生成的随机性。较低的值（如 0.1）高度确定，适合提取结构化 JSON。
LLM_TEMPERATURE=0.1

# Maximum seconds to wait for each LiteLLM text, vision, or embedding request.
# 每次 LiteLLM 文本、视觉或嵌入请求的最大等待秒数。
LLM_REQUEST_TIMEOUT_SECONDS=60

# -----------------------------------------------------------------------------
# AI service logging / AI 服务日志
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Vertex AI specific settings
# Vertex AI 专属设置
# -----------------------------------------------------------------------------
VERTEX_PROJECT_ID=ser594-ai-service
VERTEX_LOCATION=global

# Path to your downloaded Google Cloud Service Account JSON key file.
# 请填写您下载的 Google Cloud 服务账号 JSON 密钥文件的绝对路径。
# 請填寫您下載的 Google Cloud 服務帳號 JSON 金鑰檔案的絕對路徑。
# MUST be an absolute path. Relative paths/filenames will be treated as named volumes.
# 必须使用绝对路径。相对路径或纯文件名会被识别为命名卷而报错。
# 必須使用絕對路徑。相對路徑或純檔案名會被識別為命名卷而報錯。
# Example / 示例 / 範例: VERTEX_CREDENTIALS=/home/user/service-account.json
VERTEX_CREDENTIALS=
