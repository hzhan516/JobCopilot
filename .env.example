# =============================================================================
# 智能求职助手 - 环境变量配置模板
# 复制为 .env 文件后填入实际值
# =============================================================================

# -----------------------------------------------------------------------------
# Gemini API 配置（必需）
# -----------------------------------------------------------------------------
GEMINI_API_KEY=your-gemini-api-key-here

# -----------------------------------------------------------------------------
# JWT 密钥配置（生产环境必须修改）
# -----------------------------------------------------------------------------
JWT_SECRET=your-256-bit-secret-key-change-in-production-minimum-32-characters

# -----------------------------------------------------------------------------
# 数据库配置（可选，使用默认值）
# -----------------------------------------------------------------------------
# POSTGRES_USER=resume_user
# POSTGRES_PASSWORD=resume_pass
# POSTGRES_DB=resume_assistant

# -----------------------------------------------------------------------------
# RabbitMQ 配置（可选，使用默认值）
# -----------------------------------------------------------------------------
# RABBITMQ_USER=guest
# RABBITMQ_PASS=guest

# -----------------------------------------------------------------------------
# Spring Boot 配置
# -----------------------------------------------------------------------------
# 激活的配置文件：dev（开发）/ prod（生产）
SPRING_PROFILES_ACTIVE=dev

# -----------------------------------------------------------------------------
# AI 服务配置
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
GEMINI_TEXT_MODEL=gemini-2.0-flash
GEMINI_VISION_MODEL=gemini-2.0-flash
