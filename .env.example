# =============================================================================
# Resume Assistant - Environment Variables Template
# 简历助手 - 环境变量模板
#
# Please copy this file to `.env`, then fill in the secret values.
# 请将此文件复制为 `.env`，然后填写相应的密钥值。
#
# The only value you must provide for LiteLLM is your free Gemini API key below.
# 您唯一需要为 LiteLLM 提供的值是下方免费的 Gemini API 密钥。
# =============================================================================

# -----------------------------------------------------------------------------
# Database / PostgreSQL
# 数据库 / PostgreSQL
# -----------------------------------------------------------------------------
# These match the Docker Compose defaults.
# 这些值与 Docker Compose 的默认设置保持一致。
POSTGRES_DB=resume_assistant
POSTGRES_USER=resume_user
POSTGRES_PASSWORD=resume_pass
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# -----------------------------------------------------------------------------
# Message Queue / RabbitMQ
# 消息队列 / RabbitMQ
# -----------------------------------------------------------------------------
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest

# -----------------------------------------------------------------------------
# Authentication / JWT
# 身份验证 / JWT
# -----------------------------------------------------------------------------
# replace this with a strong random secret.
# 请将其替换为一个高强度的随机密钥。
JWT_SECRET=change-this-to-a-long-random-secret-at-least-32-characters

# -----------------------------------------------------------------------------
# Frontend / Web app
# 前端 / Web 应用
# -----------------------------------------------------------------------------
VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
VITE_API_BASE_URL=

# -----------------------------------------------------------------------------
# Spring Boot / Backend
# Spring Boot / 后端
# -----------------------------------------------------------------------------
SPRING_PROFILES_ACTIVE=dev

# -----------------------------------------------------------------------------
# LiteLLM + LLM API Keys
# -----------------------------------------------------------------------------
# just copy this file to `.env` and add your free Gemini API key here.
# 只需将此文件复制为 `.env`，并在此处添加您免费的 Gemini API 密钥。
#
# NO CREDIT CARD or GCP billing is required anymore, just a free API key from Google AI Studio.
# 不再需要信用卡或 GCP 计费，只需从 Google AI Studio 获取一个免费的 API 密钥即可。
#
# If you already have preferred model names, you can keep the defaults below.
# 如果您已经有首选的模型名称，可以保留下方的默认值。
GEMINI_API_KEY=[replace-with-your-gemini-api-key]
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=

OLLAMA_API_BASE=http://localhost:11434
LLM_TEXT_MODEL=gemini/gemini-3.1-flash-lite-preview
LLM_VISION_MODEL=gemini/gemini-3.1-flash-lite-preview
LLM_EMBEDDING_MODEL=gemini/gemini-embedding-001

# -----------------------------------------------------------------------------
# AI service logging
# AI 服务日志
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Optional Vertex AI settings (kept for local/legacy workflows)
# 可选的 Vertex AI 设置（保留用于本地或旧版工作流）
# -----------------------------------------------------------------------------
GOOGLE_CLOUD_PROJECT=ser594-ai-service
VERTEX_AI_LOCATION=global

# -----------------------------------------------------------------------------
# Model Parameters / 模型参数
# -----------------------------------------------------------------------------
# Controls the randomness of the AI. Lower values (e.g., 0.1) are highly deterministic.
# 控制 AI 生成的随机性。较低的值（如 0.1）高度确定，适合提取结构化 JSON。
LLM_TEMPERATURE=0.1
